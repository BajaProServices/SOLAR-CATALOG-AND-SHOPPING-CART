            { sku: "PV-INA-ATF-VT", desc: "AUTOTRANSFORMADOR 120/240 VAC", volt: "120/240V", price: 314.34, cat: "ACC", stock: 10, img: "victron.png" },
            { sku: "PV-INA-SS450-VT", desc: "SMARTSOLAR MPPT RS 450/100 TR+", volt: "450VDC", price: 740.22, cat: "ACC", stock: 10, img: "victron.png" },
            { sku: "PV-INA-SS100-VT", desc: "SMART SOLAR 100/20", volt: "100VDC", price: 94.79, cat: "ACC", stock: 25, img: "victron.png" },
            { sku: "PV-INA-SS150-VT", desc: "SMART SOLAR 150/35", volt: "150VDC", price: 123.37, cat: "ACC", stock: 25, img: "victron.png" },
            { sku: "PV-INA-SS250-VT", desc: "SMART SOLAR 250/100", volt: "250VDC", price: 408.98, cat: "ACC", stock: 10, img: "victron.png" },
            { sku: "PV-INA-SSH-VT", desc: "SMART SHUNT 500", volt: "N/A", price: 83.66, cat: "ACC", stock: 25, img: "victron.png" },
            { sku: "PV-INA-CGXMK2-VT", desc: "ACC VICTRON CERBO MK2 GX", volt: "N/A", price: 179.13, cat: "ACC", stock: 15, img: "victron.png" },
            { sku: "PV-INA-TOU50-VT", desc: "ACC VICTRON GX TOUCH 50", volt: "N/A", price: 133.51, cat: "ACC", stock: 15, img: "victron.png" },
            { sku: "PV-INA-EKRGX-VT", desc: "ACC VICTRON EKRANO GX", volt: "N/A", price: 363.35, cat: "ACC", stock: 10, img: "victron.png" },
            { sku: "PV-INA-LYNX-VT", desc: "ACC VICTRON LYNX POWER M8", volt: "N/A", price: 94.64, cat: "ACC", stock: 15, img: "victron.png" },
            { sku: "PV-INA-LYDT-VT", desc: "ACC VICTRON LYNX DISTRIBUTOR M8", volt: "N/A", price: 131.82, cat: "ACC", stock: 15, img: "victron.png" },
            { sku: "PV-INA-MK3-VT", desc: "ACC VICTRON MK3-USB", volt: "N/A", price: 48.17, cat: "ACC", stock: 30, img: "victron.png" },
            { sku: "PV-INA-F250-VT", desc: "ACC VICTRON FUSIBLE 250A/58V", volt: "48V", price: 20.70, cat: "ACC", stock: 100, img: "victron.png" },
            { sku: "PV-INA-F3005-VT", desc: "ACC VICTRON FUSIBLE 300A/80V (5 PZAS)", volt: "48V", price: 25.77, cat: "ACC", stock: 100, img: "victron.png" },
            { sku: "PV-INA-PMF-VT", desc: "ACC VICTRON PORTAFUSIBLE MEGAFUSE", volt: "N/A", price: 8.03, cat: "ACC", stock: 100, img: "victron.png" },
            { sku: "PV-BT-LV5K-BYD", desc: "BAT BYD LITIO 5KWH LV FLEX LITE", volt: "48V", price: 994.22, cat: "BAT", stock: 8, img: "byd.png" },
            { sku: "PV-HUB-BMU-BYD", desc: "ACC BYD CONTROLADOR LV BMU", volt: "N/A", price: 104.62, cat: "ACC", stock: 50, img: "byd.png" },
            { sku: "PV-ACC-ALF-BYD", desc: "ACC BYD SOPORTE AJUSTABLE LV (4 PZAS)", volt: "N/A", price: 5.84, cat: "ACC", stock: 50, img: "byd.png" },
            { sku: "PV-HUB-BCUHV-BYD", desc: "ACC BYD CONTROLADOR HV BCU", volt: "HV", price: 473.71, cat: "ACC", stock: 10, img: "byd.png" },
            { sku: "PV-BAT-7K-HUA", desc: "BAT HUAWEI 7K HV LI-ION", volt: "HV", price: 2111.66, cat: "BAT", stock: 5, img: "huawei.png" },
            { sku: "PV-ACC-BAT-AXE5-GRW", desc: "BATERÍA GROWATT AXE 5.0L (COBALTO FREE)", volt: "48V", price: 844.16, cat: "BAT", stock: 8, img: "growatt.png" },
            { sku: "PV-ACC-BAT-ALP5-GRW", desc: "BATERÍA GROWATT ALP 5.0L", volt: "48V", price: 808.67, cat: "BAT", stock: 8, img: "growatt.png" },
            { sku: "PV-BAT-INFI-GRW", desc: "BAT PORTABLE GROWATT INFINITY 1500", volt: "110V AC OUT", price: 884.34, cat: "BAT", stock: 5, img: "growatt.png" },
            { sku: "PV-KIT-CAT-GRW", desc: "KIT CABLES MULTI TORRES GROWATT", volt: "N/A", price: 77.57, cat: "ACC", stock: 50, img: "growatt.png" },
            { sku: "PV-ACC-BAT-HUB-GRW", desc: "ACC GROWATT ARK LV HUB-A1", volt: "N/A", price: 252.82, cat: "ACC", stock: 20, img: "growatt.png" },
            { sku: "PV-ACC-BAT-AXCB-GRW", desc: "ACC GROWATT CABLES BATERIA AXE", volt: "N/A", price: 63.38, cat: "ACC", stock: 50, img: "growatt.png" },
            { sku: "PV-ACC-BAS-ALP-GRW", desc: "ACC GROWATT BASE BATERIA ALP", volt: "N/A", price: 57.46, cat: "ACC", stock: 50, img: "growatt.png" },
            { sku: "PV-BT-10KLV-SOL", desc: "BAT SOLUNA 10KW LV LI-ION", volt: "48V", price: 1647.75, cat: "BAT", stock: 8, img: "soluna.png" },
            { sku: "PV-ACC-CJA-SOL", desc: "ACC SOLUNA CAJA CONEXION PARALELO", volt: "N/A", price: 81.12, cat: "ACC", stock: 20, img: "soluna.png" },
            { sku: "PV-BT-105-PM", desc: "BATERIA DEKA MARINE 105AH 12V", volt: "12V", price: 138.81, cat: "BAT", stock: 20, img: "deka.png" },
            { sku: "PV-BT-180-PM", desc: "BATERIA DEKA 180AH 12V", volt: "12V", price: 208.94, cat: "BAT", stock: 20, img: "deka.png" },
            { sku: "PV-BT-115-US", desc: "BATERIA ULTRASTART 115AH 12V CICLO PROFUNDO", volt: "12V", price: 117.67, cat: "BAT", stock: 20, img: "ultrastart.png" }
        ];

        function initApp() {
            renderTabs();
            renderProducts('TODOS');
            updateCartUI();
        }

        function renderTabs() {
            const categories = ['TODOS', ...new Set(products.map(p => p.cat))];
            const container = document.getElementById('tabs-container');
            container.innerHTML = categories.map(cat => `
                <button onclick="filterProducts('${cat}')" 
                        class="tab-btn px-6 py-4 transition-all hover:bg-aqua-accent" 
                        data-cat="${cat}">
                    ${cat === 'ACC' ? i18n[currentLang].acc : cat}
                </button>
            `).join('');
            setActiveTab('TODOS');
        }

        function filterProducts(cat) {
            renderProducts(cat);
            setActiveTab(cat);
        }

        function setActiveTab(cat) {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('tab-active');
                if(btn.dataset.cat === cat) btn.classList.add('tab-active');
            });
        }

        function renderProducts(filter = 'TODOS') {
            const grid = document.getElementById('product-grid');
            const filtered = filter === 'TODOS' ? products : products.filter(p => p.cat === filter);
            
            grid.innerHTML = filtered.map(p => `
                <div class="bg-white rounded-2xl p-5 card-shadow flex flex-col justify-between product-card border border-aqua-light/30">
                    <div>
                        <div class="relative mb-4 overflow-hidden rounded-xl bg-aqua-light/20">
                            <img src="${p.img}" alt="${p.desc}" class="w-full h-48 object-contain p-4 mix-blend-multiply" onerror="this.src='https://via.placeholder.com/300x300?text=Solar+Product'">
                            <span class="absolute top-2 right-2 bg-aqua-base text-white text-[10px] px-2 py-1 rounded-full font-bold">
                                ${p.cat}
                            </span>
                        </div>
                        <h3 class="font-bold text-aqua-dark text-sm mb-1 h-10 overflow-hidden">${p.desc}</h3>
                        <p class="text-slate-400 text-[10px] font-mono mb-2">SKU: ${p.sku}</p>
                        <div class="flex justify-between items-end mb-4">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase font-bold">${i18n[currentLang].volt} ${p.volt}</p>
                                <p class="text-2xl font-black text-aqua-base">$${p.price.toLocaleString()} <span class="text-xs font-normal">USD</span></p>
                            </div>
                            <p class="text-[10px] ${p.stock > 0 ? 'text-green-600' : 'text-red-500'} font-bold">
                                ${i18n[currentLang].stock} ${p.stock}
                            </p>
                        </div>
                    </div>
                    <button onclick="addToCart('${p.sku}')" 
                            class="w-full bg-aqua-base hover:bg-aqua-dark text-white font-bold py-3 rounded-xl transition-all flex items-center justify-center gap-2 group">
                        <i class="fas fa-cart-plus group-hover:scale-110 transition-transform"></i>
                        ${i18n[currentLang].add}
                    </button>
                </div>
            `).join('');
        }

        function toggleCart() {
            const sidebar = document.getElementById('cart-sidebar');
            sidebar.classList.toggle('translate-x-full');
        }

        function addToCart(sku) {
            const product = products.find(p => p.sku === sku);
            const itemInCart = cart.find(item => item.sku === sku);

            if (itemInCart) {
                if (itemInCart.qty < product.stock) {
                    itemInCart.qty++;
                } else {
                    alert(currentLang === 'es' ? "Stock máximo alcanzado" : "Maximum stock reached");
                    return;
                }
            } else {
                cart.push({ ...product, qty: 1 });
            }
            updateCartUI();
            if (document.getElementById('cart-sidebar').classList.contains('translate-x-full')) {
                toggleCart();
            }
        }

        function updateCartUI() {
            const container = document.getElementById('cart-items');
            const totalDisplay = document.getElementById('cart-total');
            const counter = document.getElementById('cart-counter');
            
            if (cart.length === 0) {
                container.innerHTML = `<div class="text-center py-10 opacity-50"><i class="fas fa-box-open text-4xl mb-2"></i><p>${i18n[currentLang].empty}</p></div>`;
                totalDisplay.innerText = "$0.00 USD";
                counter.innerText = "0";
                return;
            }

            let total = 0;
            let totalItems = 0;

            container.innerHTML = cart.map(item => {
                const subtotal = item.price * item.qty;
                total += subtotal;
                totalItems += item.qty;
                return `
                    <div class="flex items-center gap-4 bg-aqua-light/10 p-3 rounded-xl border border-aqua-light/50">
                        <img src="${item.img}" class="w-16 h-16 object-contain bg-white rounded-lg p-1" onerror="this.src='https://via.placeholder.com/100x100?text=Solar'">
                        <div class="flex-grow">
                            <h4 class="text-xs font-bold text-aqua-dark line-clamp-1">${item.desc}</h4>
                            <p class="text-[10px] text-slate-400 font-mono">${item.sku}</p>
                            <div class="flex items-center justify-between mt-2">
                                <div class="flex items-center border border-aqua-base/30 rounded-lg bg-white overflow-hidden">
                                    <button onclick="changeQty('${item.sku}', -1)" class="px-2 py-1 hover:bg-aqua-light text-aqua-dark">-</button>
                                    <span class="px-3 text-xs font-bold">${item.qty}</span>
                                    <button onclick="changeQty('${item.sku}', 1)" class="px-2 py-1 hover:bg-aqua-light text-aqua-dark">+</button>
                                </div>
                                <p class="text-sm font-black text-aqua-base">$${subtotal.toLocaleString()} <span class="text-[10px]">USD</span></p>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            totalDisplay.innerText = `$${total.toLocaleString()} USD`;
            counter.innerText = totalItems;
        }

        function changeQty(sku, delta) {
            const item = cart.find(i => i.sku === sku);
            const product = products.find(p => p.sku === sku);
            
            if (item) {
                item.qty += delta;
                if (item.qty <= 0) {
                    cart = cart.filter(i => i.sku !== sku);
                } else if (item.qty > product.stock) {
                    item.qty = product.stock;
                }
            }
            updateCartUI();
        }

        function changeLanguage(lang) {
            currentLang = lang;
            document.documentElement.lang = lang;
            document.getElementById('cart-label').innerText = i18n[lang].cartL;
            document.getElementById('total-label').innerText = i18n[lang].totalL;
            document.getElementById('btn-quote-label').innerText = i18n[lang].btnQ;
            renderTabs();
            renderProducts();
            updateCartUI();
        }

        function sendWhatsApp() {
            if (cart.length === 0) return alert(i18n[currentLang].empty);
            let total = 0;
            let message = currentLang === 'es' ? "*SOLICITUD DE COTIZACIÓN - BAJA PRO-SERVICES*\n" : "*QUOTE REQUEST - BAJA PRO-SERVICES*\n";
            message += "--------------------------------------\n";
            cart.forEach(item => {
                const subtotal = item.price * item.qty;
                total += subtotal;
                message += `📦 *SKU:* ${item.sku}\n📝 *Desc:* ${item.desc}\n🔹 *Cant:* ${item.qty} x $${item.price.toLocaleString()} USD\n💰 *Subtotal:* $${subtotal.toLocaleString()} USD\n--------------------------------------\n`;
            });
            message += `\n*TOTAL GLOBAL:* $${total.toLocaleString()} USD`;
            window.open(`https://wa.me/526122198325?text=${encodeURIComponent(message)}`, '_blank');
        }

        document.addEventListener('DOMContentLoaded', initApp);
    </script>
</body>
</html>
