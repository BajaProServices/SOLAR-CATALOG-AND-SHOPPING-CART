<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BAJA PRO-SERVICES | Solar Shop</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --aqua-light: #e0f2f1;
            --aqua-base: #009688;
            --aqua-dark: #00695c;
            --aqua-accent: #26a69a;
        }
        .bg-aqua-base { background-color: var(--aqua-base); }
        .text-aqua-base { color: var(--aqua-base); }
        .border-aqua-base { border-color: var(--aqua-base); }
        .hover-aqua:hover { background-color: var(--aqua-dark); }
        
        .hero-section {
            width: 100%;
            height: 450px;
            background-image: url('hero.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .tab-active { border-bottom: 4px solid white; font-weight: bold; }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 150, 136, 0.1), 0 8px 10px -6px rgba(0, 150, 136, 0.1); }
        
        .locations-bar {
            background: var(--aqua-dark);
            color: white;
            padding: 15px 0;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 1px;
            border-bottom: 4px solid var(--aqua-accent);
        }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-800">

    <nav class="bg-white sticky top-0 z-50 shadow-sm border-b border-aqua-light">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="w-10 h-10 bg-aqua-base rounded-full flex items-center justify-center text-white font-bold">BPS</div>
                <span class="text-xl font-black tracking-tighter text-aqua-dark">BAJA PRO-SERVICES</span>
            </div>
            
            <div class="flex items-center gap-4 md:gap-8">
                <select id="lang-selector" onchange="changeLanguage(this.value)" class="bg-transparent border-none text-sm font-semibold cursor-pointer outline-none text-aqua-dark">
                    <option value="es">ES 🇲🇽</option>
                    <option value="en">EN 🇺🇸</option>
                </select>
                
                <button onclick="toggleCart()" class="relative p-2 text-aqua-dark hover:text-aqua-base transition-colors">
                    <i class="fas fa-shopping-bag text-2xl"></i>
                    <span id="cart-counter" class="absolute top-0 right-0 bg-red-500 text-white text-[10px] font-bold rounded-full w-5 h-5 flex items-center justify-center">0</span>
                </button>
            </div>
        </div>
    </nav>

    <header class="hero-section"></header>

    <div class="locations-bar">
        <div class="container mx-auto px-4">
            LA PAZ • CABO SAN LUCAS • SAN JOSE DEL CABO • LORETO • MULEGE • LA RIBERA • LOS BARRILES • TODO SANTOS
        </div>
    </div>

    <div class="bg-aqua-base sticky top-[65px] z-40 shadow-md">
        <div class="container mx-auto overflow-x-auto no-scrollbar">
            <div id="tabs-container" class="flex items-center py-1 text-white uppercase text-xs font-bold tracking-widest">
            </div>
        </div>
    </div>

    <main class="container mx-auto px-4 py-12">
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        </div>
    </main>

    <div id="cart-sidebar" class="fixed inset-y-0 right-0 w-full max-w-md bg-white shadow-2xl z-[60] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-aqua-light">
        <div class="flex flex-col h-full">
            <div class="p-6 bg-aqua-dark text-white flex justify-between items-center">
                <h2 id="cart-label" class="text-xl font-bold">Carrito de Cotización</h2>
                <button onclick="toggleCart()" class="text-white text-2xl hover:rotate-90 transition-transform">&times;</button>
            </div>
            
            <div id="cart-items" class="flex-grow overflow-y-auto p-6 space-y-4">
            </div>
            
            <div class="p-6 border-t border-aqua-light bg-aqua-light/20">
                <div class="flex justify-between items-center mb-6">
                    <span id="total-label" class="text-lg font-bold text-aqua-dark">Total estimado:</span>
                    <span id="cart-total" class="text-2xl font-black text-aqua-base">$0.00 USD</span>
                </div>
                <button onclick="sendWhatsApp()" class="w-full bg-aqua-base hover:bg-aqua-dark text-white font-bold py-4 rounded-xl flex items-center justify-center gap-3 transition-all shadow-lg">
                    <i class="fab fa-whatsapp text-2xl"></i>
                    <span id="btn-quote-label">SOLICITAR COTIZACIÓN</span>
                </button>
            </div>
        </div>
    </div>

